{
  "name": "ccakashic",
  "version": "0.2.4",
  "description": "Browse Claude Code session logs (~/.claude/projects/) as beautiful HTML in your browser — an Akashic Record of your Claude Code sessions",
  "bin": {
    "ccakashic": "dist/bin/ccakashic.js"
  },
  "files": [
    "dist",
    "vendor",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "start": "npm run build && node dist/bin/ccakashic.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepack": "npm run build"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "keywords": [
    "claude",
    "claude-code",
    "session",
    "history",
    "viewer",
    "log",
    "jsonl",
    "html",
    "akashic"
  ],
  "author": "ashimon83",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ashimon83/ccakashic.git"
  },
  "homepage": "https://github.com/ashimon83/ccakashic#readme",
  "bugs": {
    "url": "https://github.com/ashimon83/ccakashic/issues"
  }
}
